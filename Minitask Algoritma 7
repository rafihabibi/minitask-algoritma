FUNCTION hitungPenggunaanListrik
  DECLARE totalGunaListrik : num

BEGIN
  Input(totalGunaListrik)
  IF totalGunaListrik > 200
  THEN
    totalGunaListrik <- totalGunaListrik * 5000
    OUTPUT(totalGunaListrik)
  ELSEIF totalGunaListrik > 100
  THEN
    totalGunaListrik <- totalGunaListrik * 3000
    OUTPUT(totalGunaListrik)
  ELSE
    totalGunaListrik <- totalGunaListrik * 2000
    OUTPUT(totalGunaListrik)
  ENDIF
END
